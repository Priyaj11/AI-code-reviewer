{
  "name": "ai-code-reviewer",
  "version": "1.0.0",
  "type": "module",
  "description": "GitHub App that automatically reviews pull requests using an LLM",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "worker": "tsx watch src/workers/reviewWorker.ts",
    "build": "tsc && npm run build:dashboard",
    "build:dashboard": "vite build --config vite.dashboard.config.ts",
    "start": "node dist/server.js",
    "start:worker": "node dist/workers/reviewWorker.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "github-app",
    "code-review",
    "llm",
    "openai"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@octokit/auth-app": "^7.1.3",
    "@octokit/rest": "^21.0.2",
    "bullmq": "^5.34.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "openai": "^4.77.0",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "vitest": "^2.1.8"
  }
}
